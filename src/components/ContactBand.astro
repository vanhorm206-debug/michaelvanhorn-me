---
import { site } from '../data/site.ts';

interface Props {
	title?: string;
}

const { title = "Let's talk about AI and people." } = Astro.props;
---

<section class="contact-band" aria-labelledby="contact-band-title">
	<div class="contact-inner wide">
		<h2 id="contact-band-title">{title}</h2>
		<div class="contact-links">
			<a href={`mailto:${site.email}`}>{site.email}</a>
			<a href={site.linkedin}>LinkedIn</a>
			<a href={site.github}>GitHub</a>
			<span>michaelvanhorn.me</span>
		</div>
	</div>
</section>

<style>
	.contact-band {
		background: var(--green);
		color: var(--paper);
	}

	.contact-inner {
		display: grid;
		gap: 1rem;
		padding-block: clamp(2.5rem, 6vw, 4rem);
	}

	h2 {
		color: var(--paper);
		font-size: clamp(2rem, 6vw, 3.25rem);
		max-width: 720px;
	}

	.contact-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.25rem;
	}

	a,
	span {
		color: var(--paper);
		font-size: 1rem;
	}
</style>
