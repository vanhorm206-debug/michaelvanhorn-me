---
import ContactBand from '../ContactBand.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeading from '../SectionHeading.astro';
import { site } from '../../data/site.ts';
import { useTranslations, type Locale } from '../../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const findings = [
	t('research.findings.1'),
	t('research.findings.2'),
	t('research.findings.3'),
	t('research.findings.4'),
	t('research.findings.5'),
];

const studyDetails = [
	{ label: t('research.details.data.label'), value: t('research.details.data.value') },
	{ label: t('research.details.sample.label'), value: t('research.details.sample.value') },
	{ label: t('research.details.method.label'), value: t('research.details.method.value') },
	{ label: t('research.details.review.label'), value: t('research.details.review.value') },
	{ label: t('research.details.output.label'), value: t('research.details.output.value') },
	{ label: t('research.details.limitation.label'), value: t('research.details.limitation.value') },
];
---

<PageLayout title={t('research.meta.title')} description={t('research.meta.description')}>
	<section class="research-page" aria-labelledby="research-title">
		<div class="wide research-inner">
			<div class="page-heading">
				<p class="kicker">{t('research.hero.kicker')}</p>
				<h1 id="research-title">{t('research.hero.title')}</h1>
				<p class="lead">{t('research.hero.lead')}</p>
				<p class="byline">{t('research.hero.byline')}</p>
			</div>
		</div>
	</section>

	<section class="research-section" aria-labelledby="abstract-title">
		<div class="wide section-inner prose">
			<SectionHeading kicker={t('research.abstract.kicker')} title={t('research.abstract.title')} accent="green" id="abstract-title" />
			<p>{t('research.abstract.body')}</p>
		</div>
	</section>

	<section class="research-section card-section" aria-labelledby="approach-title">
		<div class="wide section-inner prose">
			<SectionHeading kicker={t('research.approach.kicker')} title={t('research.approach.title')} id="approach-title" />
			<p>{t('research.approach.p1')}</p>
			<p>{t('research.approach.p2')}</p>
			<dl class="study-details">
				{studyDetails.map((detail) => <div><dt>{detail.label}</dt><dd>{detail.value}</dd></div>)}
			</dl>
		</div>
	</section>

	<section class="research-section" aria-labelledby="findings-title">
		<div class="wide section-inner">
			<SectionHeading kicker={t('research.findings.kicker')} title={t('research.findings.title')} id="findings-title" />
			<ul class="findings">
				{findings.map((finding) => <li>{finding}</li>)}
			</ul>
		</div>
	</section>

	<section class="research-section card-section" aria-labelledby="access-title">
		<div class="wide section-inner prose">
			<SectionHeading kicker={t('research.access.kicker')} title={t('research.access.title')} accent="green" id="access-title" />
			<p>
				{t('research.access.beforeEmail')}<a href={`mailto:${site.email}`}>{site.email}</a>.
			</p>
		</div>
	</section>

	<ContactBand title={t('research.contact.title')} />
</PageLayout>

<style>
	.research-page,
	.research-section {
		background: var(--paper);
		border-bottom: 1px solid var(--line);
	}

	.card-section {
		background: var(--card);
	}

	.research-inner {
		padding-block: clamp(3rem, 8vw, 5.5rem);
	}

	.page-heading {
		display: grid;
		gap: 0.75rem;
		max-width: var(--maxw-prose);
	}

	.page-heading h1 {
		font-size: clamp(2.2rem, 6vw, 3.5rem);
		letter-spacing: 0;
	}

	.lead {
		color: var(--muted);
		font-size: clamp(1.1rem, 2.2vw, 1.3rem);
		max-width: var(--maxw-prose);
	}

	.byline {
		color: var(--muted);
		font-size: 0.95rem;
	}

	.section-inner {
		display: grid;
		gap: clamp(1.25rem, 3vw, 2rem);
		padding-block: var(--space-section);
		max-width: var(--maxw-prose);
	}

	.section-inner p {
		color: var(--ink);
		font-size: clamp(1.05rem, 2vw, 1.18rem);
	}

	.section-inner a {
		color: var(--clay);
	}

	.findings {
		display: grid;
		gap: 1rem;
		margin: 0;
		max-width: var(--maxw-prose);
		padding-left: 1.4rem;
	}

	.findings li {
		color: var(--ink);
		font-size: clamp(1.05rem, 2vw, 1.18rem);
		padding-left: 0.25rem;
	}

	.study-details {
		margin: 1rem 0 0;
		display: grid;
		border-top: 1px solid var(--line);
		max-width: var(--maxw-prose);
	}

	.study-details > div {
		display: grid;
		grid-template-columns: 9.5rem 1fr;
		gap: 1rem;
		padding: 0.7rem 0;
		border-bottom: 1px solid var(--line);
	}

	.study-details dt {
		color: var(--muted);
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding-top: 0.2rem;
	}

	.study-details dd {
		margin: 0;
		color: var(--ink);
		font-size: clamp(1rem, 2vw, 1.08rem);
	}

	@media (max-width: 560px) {
		.study-details > div {
			grid-template-columns: 1fr;
			gap: 0.15rem;
		}
	}
</style>
