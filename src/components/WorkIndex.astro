---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import ProjectCard from './ProjectCard.astro';
import { localeFromEntryId, localizePath, useTranslations, type Locale } from '../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = (await getCollection('work'))
	.filter((project) => !project.data.draft)
	.map((project) => ({ project, parsed: localeFromEntryId(project.id) }))
	.filter(({ parsed }) => parsed.locale === lang)
	.sort((a, b) => a.project.data.order - b.project.data.order);
---

<PageLayout title={t('work.meta.title')} description={t('work.meta.description')}>
	<section class="work-index" aria-labelledby="work-title">
		<div class="wide work-inner">
			<div class="intro">
				<div class="page-heading">
					<p class="kicker">{t('work.kicker')}</p>
					<h1 id="work-title">{t('work.heading')}</h1>
				</div>
				<p>{t('work.intro')}</p>
			</div>

			<div class="project-grid">
				{
					projects.map(({ project, parsed }) => (
						<ProjectCard
							name={project.data.title}
							blurb={project.data.summary}
							href={localizePath(`/work/${parsed.slug}`, lang)}
						/>
					))
				}
			</div>
		</div>
	</section>
</PageLayout>

<style>
	.work-index {
		background: var(--paper);
		border-bottom: 1px solid var(--line);
	}

	.work-inner {
		display: grid;
		gap: clamp(1.5rem, 4vw, 2.5rem);
		padding-block: var(--space-section);
	}

	.intro {
		display: grid;
		gap: 1rem;
		max-width: var(--maxw-prose);
	}

	.page-heading {
		display: grid;
		gap: 0.55rem;
	}

	.page-heading h1 {
		font-size: clamp(1.8rem, 5vw, 3rem);
		letter-spacing: 0;
	}

	.intro p {
		color: var(--muted);
		font-size: clamp(1rem, 2vw, 1.15rem);
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	@media (max-width: 760px) {
		.project-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
