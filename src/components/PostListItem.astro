---
import { type Locale } from '../i18n/ui';

interface Props {
	title: string;
	date?: Date;
	dek?: string;
	href: string;
	external?: boolean;
	meta?: string;
	locale?: Locale;
}

const { title, date, dek, href, external = false, meta, locale = 'en' } = Astro.props;
const formattedDate = date
	? new Intl.DateTimeFormat(locale, {
			month: 'long',
			day: 'numeric',
			year: 'numeric',
			timeZone: 'UTC',
		}).format(date)
	: undefined;
const label = formattedDate ?? meta;
const externalAttrs = external ? { target: '_blank', rel: 'noopener' } : {};
---

<article class="post-list-item">
	{label && <p class="date">{label}</p>}
	<h3><a href={href} {...externalAttrs}>{title}</a></h3>
	{dek && <p class="dek">{dek}</p>}
</article>

<style>
	.post-list-item {
		display: grid;
		gap: 0.35rem;
		border-top: 1px solid var(--line);
		padding-block: 1.1rem;
	}

	.date,
	.dek {
		color: var(--muted);
	}

	.date {
		font-size: 0.85rem;
	}

	h3 {
		font-size: clamp(1.25rem, 3vw, 1.6rem);
	}

	h3 a {
		color: var(--ink);
		text-decoration: none;
	}

	h3 a:hover {
		color: var(--clay);
		text-decoration: underline;
	}
</style>
