---
interface Props {
	org: string;
	role: string;
	dates: string;
}

const { org, role, dates } = Astro.props;
---

<article class="experience-item">
	<h3>{org}</h3>
	<p>{role} · {dates}</p>
</article>

<style>
	.experience-item {
		display: grid;
		gap: 0.2rem;
		border-top: 1px solid var(--line);
		padding-block: 1rem;
	}

	h3 {
		font-family: var(--font-sans);
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.3;
	}

	p {
		color: var(--muted);
		font-size: 0.95rem;
	}
</style>
