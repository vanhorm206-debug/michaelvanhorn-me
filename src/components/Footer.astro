---
import { site } from '../data/site.ts';
import { getLangFromUrl, localizePath, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const links = [
	{ href: localizePath('/work', lang), label: t('nav.work') },
	{ href: localizePath('/writing', lang), label: t('nav.writing') },
	{ href: localizePath('/about', lang), label: t('nav.about') },
	{ href: localizePath('/contact', lang), label: t('nav.contact') },
];
const localizedHome = localizePath('/', lang);
---

<footer class="site-footer">
	<div class="footer-inner wide">
		<a class="footer-brand" href={localizedHome}>Michael Van Horn</a>
		<nav class="footer-nav" aria-label={t('footer.navAria')}>
			{links.map((link) => <a href={link.href}>{link.label}</a>)}
		</nav>
		<div class="footer-contact">
			<a href={`mailto:${site.email}`}>{site.email}</a>
			<a href={site.linkedin}>LinkedIn</a>
			<a href={site.github}>GitHub</a>
			<span>michaelvanhorn.me</span>
		</div>
		{t('footer.signoff') && <p class="footer-signoff">{t('footer.signoff')}</p>}
	</div>
</footer>

<style>
	.site-footer {
		background: var(--green);
		color: var(--paper);
	}

	.footer-inner {
		display: grid;
		gap: 1.25rem;
		padding-block: clamp(2rem, 5vw, 3rem);
	}

	.footer-brand {
		color: var(--paper);
		font-family: var(--font-serif);
		font-size: 1.4rem;
		text-decoration: none;
	}

	.footer-nav,
	.footer-contact {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.25rem;
	}

	.site-footer a,
	.footer-contact span {
		color: var(--paper);
		font-size: 0.95rem;
	}

	.footer-signoff {
		color: var(--paper);
		font-size: 0.95rem;
		margin: 0;
	}

	.site-footer a:hover {
		text-decoration-thickness: 2px;
	}
</style>
