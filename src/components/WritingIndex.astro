---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import PostListItem from './PostListItem.astro';
import { localeFromEntryId, localizePath, useTranslations, type Locale } from '../i18n/ui';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const posts = (await getCollection('writing'))
	.filter((post) => !post.data.draft)
	.map((post) => ({ post, parsed: localeFromEntryId(post.id) }))
	.filter(({ parsed }) => parsed.locale === lang)
	.sort((a, b) => b.post.data.date.getTime() - a.post.data.date.getTime());
---

<PageLayout title={t('writing.meta.title')} description={t('writing.meta.description')}>
	<section class="writing-index" aria-labelledby="writing-title">
		<div class="wide writing-inner">
			<div class="intro">
				<div class="page-heading">
					<p class="kicker">{t('writing.kicker')}</p>
					<h1 id="writing-title">{t('writing.heading')}</h1>
				</div>
				<p>{t('writing.intro')}</p>
			</div>

			<div class="post-list">
				{
					posts.map(({ post, parsed }) => (
						<PostListItem
							title={post.data.title}
							date={post.data.date}
							dek={post.data.dek}
							href={localizePath(`/writing/${parsed.slug}`, lang)}
							locale={lang}
						/>
					))
				}
				<PostListItem
					title={t('writing.medium.title')}
					dek={t('writing.medium.dek')}
					href="https://medium.com/@vanho316/how-to-work-in-virtual-teams-7869b0ba951e"
					meta={t('writing.medium.meta')}
					external
				/>
			</div>
		</div>
	</section>
</PageLayout>

<style>
	.writing-index {
		background: var(--paper);
		border-bottom: 1px solid var(--line);
	}

	.writing-inner {
		display: grid;
		gap: clamp(1.5rem, 4vw, 2.5rem);
		padding-block: var(--space-section);
	}

	.intro {
		display: grid;
		gap: 1rem;
		max-width: var(--maxw-prose);
	}

	.page-heading {
		display: grid;
		gap: 0.55rem;
	}

	.page-heading h1 {
		font-size: clamp(1.8rem, 5vw, 3rem);
		letter-spacing: 0;
	}

	.intro p {
		color: var(--muted);
		font-size: clamp(1rem, 2vw, 1.15rem);
	}

	.post-list {
		display: grid;
		max-width: var(--maxw-prose);
		border-bottom: 1px solid var(--line);
	}
</style>
