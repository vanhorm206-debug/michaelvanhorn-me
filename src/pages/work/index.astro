---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';

const projects = (await getCollection('work'))
	.filter((project) => !project.data.draft)
	.sort((a, b) => a.data.order - b.data.order);

const description =
	'Projects at the edge of AI, work, and the systems that help people think clearly.';
---

<PageLayout title="Work · Michael Van Horn" description={description}>
	<section class="work-index" aria-labelledby="work-title">
		<div class="wide work-inner">
			<div class="intro">
				<SectionHeading
					kicker="Work"
					title="Built projects at the edge of AI and work."
					id="work-title"
				/>
				<p>
					A short collection of products and personal systems I have built to make AI and
					knowledge work more useful.
				</p>
			</div>

			<div class="project-grid">
				{
					projects.map((project) => (
						<ProjectCard
							name={project.data.title}
							blurb={project.data.summary}
							href={`/work/${project.id}`}
						/>
					))
				}
			</div>
		</div>
	</section>
</PageLayout>

<style>
	.work-index {
		background: var(--paper);
		border-bottom: 1px solid var(--line);
	}

	.work-inner {
		display: grid;
		gap: clamp(1.5rem, 4vw, 2.5rem);
		padding-block: var(--space-section);
	}

	.intro {
		display: grid;
		gap: 1rem;
		max-width: var(--maxw-prose);
	}

	.intro p {
		color: var(--muted);
		font-size: clamp(1rem, 2vw, 1.15rem);
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	@media (max-width: 760px) {
		.project-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
