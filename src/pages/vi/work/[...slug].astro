---
import { getCollection } from 'astro:content';
import MarkedInRedDetail from '../../../components/MarkedInRedDetail.astro';
import WorkDetail from '../../../components/WorkDetail.astro';
import { localeFromEntryId } from '../../../i18n/ui';

export async function getStaticPaths() {
	const projects = await getCollection('work', ({ data }) => !data.draft);

	return projects
		.filter((project) => localeFromEntryId(project.id).locale === 'vi')
		.map((project) => ({
			params: { slug: localeFromEntryId(project.id).slug },
			props: { project },
		}));
}

const { project } = Astro.props;
const isMarkedInRed = localeFromEntryId(project.id).slug === 'marked-in-red';
---

{isMarkedInRed ? <MarkedInRedDetail lang="vi" project={project} /> : <WorkDetail lang="vi" project={project} />}
