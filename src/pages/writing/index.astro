---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import PostListItem from '../../components/PostListItem.astro';

const posts = (await getCollection('writing'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const description = 'Notes on AI, work, and the people the shift affects.';
---

<PageLayout title="Writing · Michael Van Horn" description={description}>
	<section class="writing-index" aria-labelledby="writing-title">
		<div class="wide writing-inner">
			<div class="intro">
				<div class="page-heading">
					<p class="kicker">Writing</p>
					<h1 id="writing-title">Notes on AI and the future of work.</h1>
				</div>
				<p>Short pieces on AI adoption, job stress, and keeping the human side in view.</p>
			</div>

			<div class="post-list">
				{posts.map((post) => (
					<PostListItem
						title={post.data.title}
						date={post.data.date}
						dek={post.data.dek}
						href={`/writing/${post.id}`}
					/>
				))}
				<PostListItem
					title="How to Work in Virtual Teams"
					dek="On virtual-team group dynamics: forming, storming, norming, and performing, the roles people play, and how to collaborate well online."
					href="https://medium.com/@vanho316/how-to-work-in-virtual-teams-7869b0ba951e"
					meta="Essay · Medium"
					external
				/>
			</div>
		</div>
	</section>
</PageLayout>

<style>
	.writing-index {
		background: var(--paper);
		border-bottom: 1px solid var(--line);
	}

	.writing-inner {
		display: grid;
		gap: clamp(1.5rem, 4vw, 2.5rem);
		padding-block: var(--space-section);
	}

	.intro {
		display: grid;
		gap: 1rem;
		max-width: var(--maxw-prose);
	}

	.page-heading {
		display: grid;
		gap: 0.55rem;
	}

	.page-heading h1 {
		font-size: clamp(1.8rem, 5vw, 3rem);
		letter-spacing: 0;
	}

	.intro p {
		color: var(--muted);
		font-size: clamp(1rem, 2vw, 1.15rem);
	}

	.post-list {
		display: grid;
		max-width: var(--maxw-prose);
		border-bottom: 1px solid var(--line);
	}
</style>
