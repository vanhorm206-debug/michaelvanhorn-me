---
import Button from '../components/Button.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { getLangFromUrl, localizePath, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const to = (path: string) => localizePath(path, lang);
---

<PageLayout title={t('notFound.meta.title')} description={t('notFound.meta.description')}>
	<section class="notfound" aria-labelledby="notfound-title">
		<div class="prose notfound-inner">
			<p class="kicker">{t('notFound.kicker')}</p>
			<h1 id="notfound-title">{t('notFound.title')}</h1>
			<p class="lead">{t('notFound.lead')}</p>
			<div class="actions">
				<Button href={to('/')}>{t('notFound.home')}</Button>
				<Button href={to('/work')} variant="ghost">{t('notFound.work')}</Button>
			</div>
		</div>
	</section>
</PageLayout>

<style>
	.notfound {
		background: var(--paper);
		border-bottom: 1px solid var(--line);
	}

	.notfound-inner {
		display: grid;
		gap: 1rem;
		padding-block: clamp(4rem, 12vw, 8rem);
	}

	.notfound-inner h1 {
		font-size: clamp(2.2rem, 6vw, 3.5rem);
		letter-spacing: 0;
	}

	.lead {
		color: var(--muted);
		font-size: clamp(1.05rem, 2vw, 1.2rem);
		max-width: var(--maxw-prose);
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 0.5rem;
	}
</style>
