---
import { Image } from 'astro:assets';
import Button from '../components/Button.astro';
import ContactBand from '../components/ContactBand.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import PageLayout from '../layouts/PageLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import headshot from '../assets/headshot.png';

const description =
	'HRD researcher and builder. I study how AI adoption reshapes work and stress, and I build the tools and frameworks that make the shift humane.';
---

<PageLayout title="Michael Van Horn · The human side of AI in the workplace" description={description}>
	<section class="home-section hero">
		<div class="wide section-inner hero-inner">
			<div class="hero-content">
				<p class="kicker">The human side of AI in the workplace</p>
				<h1>I help people and organizations work <em>well</em> with AI.</h1>
				<p class="hero-copy">{description}</p>
				<div class="actions" aria-label="Homepage actions">
					<Button href="/work">Read the work</Button>
					<Button href="/contact" variant="ghost">Get in touch</Button>
				</div>
			</div>
			<div class="hero-portrait">
				<Image
					src={headshot}
					alt="Michael Van Horn"
					width={1126}
					height={1408}
					format="webp"
					widths={[240, 320, 400, 520]}
					sizes="(min-width: 880px) 400px, 250px"
					class="hero-portrait-image"
				/>
			</div>
		</div>
	</section>

	<section class="home-section card-section why-section" aria-labelledby="why-this-work-title">
		<div class="wide section-inner">
			<SectionHeading kicker="Why this work" accent="green" />
			<p id="why-this-work-title" class="statement">
				Anishinaabe, Red Lake Nation descendant. I came to AI through people: who it helps,
				who it leaves out, and how organizations carry their communities through change.
			</p>
		</div>
	</section>

	<section class="home-section" aria-labelledby="featured-research-title">
		<div class="wide section-inner research-inner">
			<SectionHeading
				kicker="Featured · Research"
				title="AI Adoption & Job Stress"
				id="featured-research-title"
			/>
			<p>
				My OLPD manuscript on how AI rollouts affect employee stress, read by leadership, made
				required reading for the executive team, and presented at the 2026 OLPD Student
				Research Conference at the University of Minnesota. The center of how I think about this work.
			</p>
			<div class="actions">
				<Button href="/about" variant="ghost">Read the manuscript</Button>
			</div>
		</div>
	</section>

	<section class="home-section card-section" aria-labelledby="selected-work-title">
		<div class="wide section-inner selected-work">
			<SectionHeading
				kicker="Selected work"
				title="Built projects at the edge of AI and work."
				id="selected-work-title"
			/>
			<div class="project-grid">
				<ProjectCard
					name="Waaban"
					blurb="AI-powered market-analysis platform. Co-founder & CEO."
					href="/work/waaban"
				/>
				<ProjectCard
					name="Woodhouse"
					blurb="Self-built task manager replacing Asana. A local dashboard backed by a private GitHub repo via an Express proxy."
					href="/work/woodhouse"
				/>
				<ProjectCard
					name="Obsidian AI"
					blurb="Personal AI memory + agent system with knowledge files, hooks, skills, and a Townfolk agent layer."
					href="/work/obsidian-ai"
				/>
			</div>
			<div class="actions">
				<Button href="/work">See all work</Button>
			</div>
		</div>
	</section>

	<section class="home-section" aria-labelledby="writing-title">
		<div class="wide section-inner writing-inner">
			<SectionHeading
				kicker="Writing"
				title="Notes on AI and the future of work."
				id="writing-title"
			/>
			<p>Short pieces on AI adoption, job stress, and keeping the human side in view.</p>
			<div class="actions">
				<Button href="/writing">Read the writing</Button>
			</div>
		</div>
	</section>

	<section class="home-section card-section" aria-labelledby="experience-title">
		<div class="wide section-inner experience-inner">
			<SectionHeading
				kicker="Experience"
				title="Where I am putting the work into practice."
				id="experience-title"
			/>
			<div class="experience-list">
				<ExperienceItem org="Meet Minneapolis" role="ECI" dates="2026–" />
				<ExperienceItem org="Waaban" role="Co-founder & CEO" dates="2026–" />
				<ExperienceItem org="EY" role="Incoming" dates="Fall 2026 · Ho Chi Minh City" />
			</div>
			<div class="actions">
				<Button href="/resume.pdf" variant="ghost">Download résumé (PDF)</Button>
			</div>
		</div>
	</section>

	<ContactBand />
</PageLayout>

<style>
	.home-section {
		border-bottom: 1px solid var(--line);
		background: var(--paper);
	}

	.card-section {
		background: var(--card);
	}

	.section-inner {
		display: grid;
		gap: clamp(1.25rem, 3vw, 2rem);
		padding-block: var(--space-section);
	}

	.hero-inner {
		gap: clamp(2rem, 5vw, 4rem);
		padding-block: clamp(4rem, 10vw, 7rem);
	}

	.hero-content {
		display: grid;
		gap: 1.2rem;
	}

	.hero-portrait {
		display: flex;
		justify-content: center;
		order: -1;
	}

	.hero-portrait-image {
		width: min(250px, 72vw);
		height: auto;
	}

	h1 {
		max-width: 900px;
		font-size: clamp(2.6rem, 9vw, 6.6rem);
		letter-spacing: 0;
		overflow-wrap: break-word;
		hyphens: auto;
	}

	h1 em {
		font-style: italic;
	}

	.hero-copy {
		max-width: 720px;
		color: var(--muted);
		font-size: clamp(1.08rem, 2vw, 1.28rem);
	}

	.statement {
		max-width: 860px;
		color: var(--ink);
		font-family: var(--font-serif);
		font-size: clamp(1.8rem, 4.8vw, 3.35rem);
		font-weight: 500;
		line-height: 1.14;
	}

	.research-inner,
	.writing-inner,
	.experience-inner {
		max-width: var(--maxw-prose);
		margin-inline: auto;
	}

	.research-inner p,
	.writing-inner p {
		color: var(--muted);
		font-size: clamp(1rem, 2vw, 1.12rem);
	}

	.selected-work {
		gap: 1.5rem;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.experience-list {
		display: grid;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	@media (min-width: 880px) {
		.hero-inner {
			grid-template-columns: minmax(0, 1fr) minmax(260px, 380px);
			align-items: end;
			gap: clamp(2rem, 4vw, 3rem);
			padding-bottom: 0;
		}

		.hero-content {
			padding-bottom: clamp(4rem, 10vw, 7rem);
		}

		h1 {
			font-size: clamp(3.8rem, 6vw, 5rem);
		}

		.hero-portrait {
			order: initial;
			align-self: end;
		}

		.hero-portrait-image {
			width: min(100%, 380px);
		}
	}

	@media (max-width: 760px) {
		.project-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
