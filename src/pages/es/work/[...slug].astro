---
import { getCollection } from 'astro:content';
import WorkDetail from '../../../components/WorkDetail.astro';
import { localeFromEntryId } from '../../../i18n/ui';

export async function getStaticPaths() {
	const projects = await getCollection('work', ({ data }) => !data.draft);

	return projects
		.filter((project) => localeFromEntryId(project.id).locale === 'es')
		.map((project) => ({
			params: { slug: localeFromEntryId(project.id).slug },
			props: { project },
		}));
}

const { project } = Astro.props;
---

<WorkDetail lang="es" project={project} />
